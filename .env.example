# ─── Site URL ────────────────────────────────────────────────────────────────
# The canonical base URL for this deployment.
# Used by: sitemap.xml, robots.txt, Open Graph, canonical tags, JSON-LD.
#
# During local development: leave as the production URL or change to http://localhost:3000
# On Vercel: set this in Project → Settings → Environment Variables → NEXT_PUBLIC_SITE_URL
# Custom domain: https://smrtcalc.com
#
NEXT_PUBLIC_SITE_URL=https://smrtcalc.com

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Your GA4 Measurement ID (format: G-XXXXXXXXXX)
# Get it from: Google Analytics → Admin → Data Streams → your stream → Measurement ID
# Leave empty to disable analytics in development.
#
NEXT_PUBLIC_GA_ID=
