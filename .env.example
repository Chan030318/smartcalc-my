# ─── Site URL ────────────────────────────────────────────────────────────────
# The canonical base URL for this deployment.
# Used by: sitemap.xml, robots.txt, Open Graph, canonical tags, JSON-LD.
#
# During local development: leave as the Vercel URL or change to http://localhost:3000
# On Vercel: set this in Project → Settings → Environment Variables
# When you have a custom domain: change to https://smartcalc.my
#
NEXT_PUBLIC_SITE_URL=https://smartcalc-my.vercel.app
